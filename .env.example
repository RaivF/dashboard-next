# Port for the Express backend.
PORT=3001

# Local 2025 campaign snapshot used for previous-year comparison.
PREVIOUS_YEAR_DATA_FILE=previous-year-data.txt

# true - read current applicants data from an Excel workbook in DATA.
APPLICANTS_XLSX_SOURCE=true

# Optional. If omitted, the server uses the first .xlsx file in DATA,
# excluding temporary files and generated unique_people_*.xlsx reports.
# APPLICANTS_XLSX_FILE=DATA/applicants.xlsx

# For development, leave * or omit the variable.
CORS_ORIGIN=*

# Yandex JavaScript API key for the separate 3D map page.
VITE_YANDEX_MAPS_API_KEY=
